[Unit]
Description=Air Quality Streamlit Dashboard
After=network.target

[Service]
Type=simple
User=exouser
WorkingDirectory=/opt/airquality
EnvironmentFile=/opt/airquality/.env
ExecStart=/opt/airquality/venv/bin/streamlit run dashboard.py \
    --server.port=8501 \
    --server.address=127.0.0.1 \
    --server.headless=true
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
